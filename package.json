{
  "name": "@nikitin_rus/metrica-tracker",
  "version": "1.0.0",
  "description": "Metrica Tracker Library",
  "author": "basilstansfield@gmail.com",
  "license": "MIT",
  "keywords": [
    "metrica",
    "web metrics",
    "metric",
    "metrics"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/metrica-service-diploma/metrica-tracker"
  },
  "homepage": "https://github.com/metrica-service-diploma/metrica-tracker#readme",
  "bugs": {
    "url": "https://github.com/metrica-service-diploma/metrica-tracker/issues"
  },
  "scripts": {
    "build": "rollup -c rollup.config.cjs",
    "dev": "rollup -c rollup.config.cjs -w",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.0.0",
    "rollup": "^3.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "rollup-plugin-terser": "^7.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.9.0+sha512.5f5f00843eae735dfab6f0442524603e987ceca55e98b36eb0120f4e58908e5b1406545321e46627dca97d15d562f23dc13fb96cabd4e6bc92d379f619001e4e"
}